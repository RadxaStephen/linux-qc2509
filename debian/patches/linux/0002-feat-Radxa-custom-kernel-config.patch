From 115b3c9d971f6d91c7284593962ade0d3cfaa7c7 Mon Sep 17 00:00:00 2001
From: Stephen Chen <stephen@radxa.com>
Date: Mon, 23 Mar 2026 13:31:07 +0800
Subject: [PATCH] feat: Radxa custom kernel config

Signed-off-by: Chongbiao Chen <chenchongbiao@radxa.com>
Signed-off-by: Stephen Chen <stephen@radxa.com>

diff --git a/src/arch/arm64/configs/radxa_custom.config b/src/arch/arm64/configs/radxa_custom.config
new file mode 100644
index 0000000000000..6c51a3836b13a
--- /dev/null
+++ b/src/arch/arm64/configs/radxa_custom.config
@@ -0,0 +1,8 @@
+# Disable kernel config CONFIG_SECURITY_APPARMOR since AppArmor is not in use
+CONFIG_SECURITY_APPARMOR=n
+
+# Kernel modules build by portage and XZ compressed fail to load with latest kmod tools.
+# DKMS: https://bugs.gentoo.org/920837
+CONFIG_MODULE_COMPRESS_XZ=n
+CONFIG_MODULE_COMPRESS_ZSTD=y
+
-- 
2.34.1

